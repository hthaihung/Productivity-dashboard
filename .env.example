# Database - Supabase PostgreSQL
# Get both connection strings from Supabase project settings > Database > Connection string

# Pooled connection (Transaction mode) - for runtime queries
# Format: postgresql://postgres.xxxxx:[password]@aws-0-xx-xxx.pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres.xxxxx:[YOUR-PASSWORD]@aws-0-xx-xxx.pooler.supabase.com:6543/postgres"

# Direct connection (Session mode) - for Prisma migrations
# Format: postgresql://postgres.xxxxx:[password]@aws-0-xx-xxx.pooler.supabase.com:5432/postgres
DIRECT_URL="postgresql://postgres.xxxxx:[YOUR-PASSWORD]@aws-0-xx-xxx.pooler.supabase.com:5432/postgres"

# NextAuth - REQUIRED
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (optional)
# Google OAuth - Get from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Rate Limiting - REQUIRED for production
# Get from https://upstash.com/ - create a Redis database
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Email Service - REQUIRED for password reset
# Get from https://resend.com/ - create an API key
RESEND_API_KEY=""
EMAIL_FROM="noreply@yourdomain.com"

# Error Monitoring - REQUIRED for production
# Get from https://sentry.io/ - create a project
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

